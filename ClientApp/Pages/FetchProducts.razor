@using System.Text.Json

@page "/fetchproducts"
@inject HttpClient Http

<h3>Product List</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <p style="color:red">@errorMessage</p>
}
else if (products?.Length > 0)
{
    <ul>
        @foreach (var product in products)
        {
            <li>
                @product.Name - $@product.Price
                (Stock: @product.Stock, Category: @product.Category?.Name)
            </li>
        }
    </ul>
}
else
{
    <p>No products found.</p>
}

@code {
    private Product[]? products;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    /// <summary>
    /// Handles API call and error management
    /// </summary>
    private async Task LoadProductsAsync()
    {
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));

            var response = await Http.GetAsync("https://orange-yodel-vgppjj5vxp63xv6q-5267.app.github.dev/api/productlist",
cts.Token);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Error: API returned {response.StatusCode}";
                return;
            }

            var json = await response.Content.ReadAsStringAsync(cts.Token);

            if (string.IsNullOrWhiteSpace(json))
            {
                errorMessage = "Error: Empty response from server.";
                return;
            }

            try
            {
                products = JsonSerializer.Deserialize<Product[]>(json, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });

                if (products == null)
                {
                    errorMessage = "Error: Empty or invalid response.";
                }
            }
            catch (JsonException ex)
            {
                errorMessage = "Something went wrong while processing data. Please try again.";
                Console.WriteLine($"JSON Error: {ex.Message}");
                Console.WriteLine($"Raw JSON: {json}");
            }
        }
        catch (TaskCanceledException)
        {
            errorMessage = "Request timed out. Please try again.";
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"Request error: {ex.Message}";
        }
        catch (NotSupportedException)
        {
            errorMessage = "Invalid response format.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class Product
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public double Price { get; set; }
        public int Stock { get; set; }

        public Category? Category { get; set; }
    }

    public class Category
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}
