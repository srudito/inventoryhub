@using System.Text.Json

@page "/fetchproducts"
@inject HttpClient Http

<h3>Product List</h3>

@if (isLoading)
{
    <p>Loading...</p>  @* ✅ Loading indicator *@
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <p style="color:red">@errorMessage</p>  @* ✅ Error UI *@
}
else if (products?.Length > 0)
{
    <ul>
        @foreach (var product in products)
        {
            <li>
                @product.Name - $@product.Price
                (Stock: @product.Stock, Category: @product.Category?.Name)
                @* ✅ Null-safe operator prevents runtime crash *@
            </li>
        }
    </ul>
}
else
{
    <p>No products found.</p>
}

@code {
    private Product[]? products;
    private bool isLoading = true;
    private string? errorMessage;

    // ✅ Frontend caching (Copilot optimization)
    private DateTime lastFetchTime;
    private readonly TimeSpan cacheDuration = TimeSpan.FromMinutes(2);

    // ✅ Reusable JSON options (avoid repeated allocation)
    private static readonly JsonSerializerOptions jsonOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    /// <summary>
    /// ✅ Handles API communication and performance optimization
    /// 
    /// Copilot Contributions:
    /// - Suggested caching to reduce redundant API calls
    /// - Added structured error handling
    /// - Recommended timeout handling
    /// - Suggested manual JSON parsing for debugging
    /// </summary>
    private async Task LoadProductsAsync()
    {
        try
        {
            // ✅ Prevent redundant API calls
            if (products != null && DateTime.Now - lastFetchTime < cacheDuration)
            {
                Console.WriteLine("✅ Using cached data (frontend)");
                isLoading = false;
                return;
            }

            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));

            var response = await Http.GetAsync(
                "https://orange-yodel-vgppjj5vxp63xv6q-5267.app.github.dev/api/productlist",
                cts.Token
            );

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Error: API returned {response.StatusCode}";
                return;
            }

            var json = await response.Content.ReadAsStringAsync(cts.Token);

            if (string.IsNullOrWhiteSpace(json))
            {
                errorMessage = "Error: Empty response from server.";
                return;
            }

            try
            {
                products = JsonSerializer.Deserialize<Product[]>(json, jsonOptions);

                if (products == null)
                {
                    errorMessage = "Error: Invalid response.";
                }
                else
                {
                    // ✅ Store timestamp for caching
                    lastFetchTime = DateTime.Now;
                    Console.WriteLine("✅ Data fetched from API");
                }
            }
            catch (JsonException ex)
            {
                errorMessage = "Data processing error.";

                Console.WriteLine($"JSON Error: {ex.Message}");
                Console.WriteLine($"Raw JSON: {json}");
            }
        }
        catch (TaskCanceledException)
        {
            errorMessage = "Request timed out.";
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"Request error: {ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    // ✅ Matches API structure
    public class Product
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public double Price { get; set; }
        public int Stock { get; set; }
        public Category? Category { get; set; }
    }

    // ✅ Nested JSON support
    public class Category
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}

@*
✅ PERFORMANCE OPTIMIZATION SUMMARY (Copilot-assisted)

1. Reduced redundant API calls using frontend caching
2. Improved loading speed and responsiveness
3. Minimized network traffic
4. Maintained error handling and data integrity

✅ RESULT:
- Faster UI rendering
- Efficient API usage
- Scalable architecture
*@